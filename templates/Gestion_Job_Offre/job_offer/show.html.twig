{% extends 'base.html.twig' %}

{% block title %}{{ offer.title }} - UniLearn{% endblock %}

{% block body %}
<div class="container mt-4">
    <div class="row justify-content-center">
        <div class="col-lg-10">
            {# Flash Messages #}
            {% for label, messages in app.flashes %}
                {% for message in messages %}
                    <div class="alert alert-{{ label == 'error' ? 'danger' : label }} alert-dismissible fade show" role="alert">
                        {{ message }}
                        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                    </div>
                {% endfor %}
            {% endfor %}

            {# Back Button #}
            <div class="mb-3">
                <a href="{{ path('app_job_offer_index') }}" class="btn btn-outline-secondary">
                    <i class="bi bi-arrow-left"></i> Back to Job Offers
                </a>
            </div>

            {# Job Offer Details Card #}
            <div class="card mb-4">
                <div class="card-header bg-primary text-white">
                    <h2 class="mb-0">
                        <i class="bi bi-briefcase-fill"></i> {{ offer.title }}
                    </h2>
                </div>
                <div class="card-body">
                    <div class="row mb-3">
                        <div class="col-md-6">
                            <h5 class="text-muted mb-2">Job Type</h5>
                            <p class="lead">
                                <span class="badge bg-info">
                                    {{ offer.type.value|replace({'_': ' '})|title }}
                                </span>
                            </p>
                        </div>
                        <div class="col-md-6">
                            <h5 class="text-muted mb-2">Status</h5>
                            <p class="lead">
                                {% include 'Gestion_Job_Offre/job_offer/_offer_status_badge.html.twig' with {status: offer.status} only %}
                            </p>
                        </div>
                    </div>

                    {% if offer.location %}
                        <div class="mb-3">
                            <h5 class="text-muted mb-2">
                                <i class="bi bi-geo-alt-fill"></i> Location
                            </h5>
                            <p>{{ offer.location }}</p>
                        </div>
                    {% endif %}

                    {# Job Location Map Display #}
                    {% if offer.latitude and offer.longitude %}
                        <div class="card mb-3">
                            <div class="card-header bg-info bg-opacity-10">
                                <h6 class="mb-0 text-info">
                                    <i class="bi bi-map"></i> Job Location on Map
                                </h6>
                            </div>
                            <div class="card-body p-0">
                                <div id="job-offer-map" 
                                     data-job-lat="{{ offer.latitude }}" 
                                     data-job-lon="{{ offer.longitude }}"
                                     style="width: 100%; height: 350px; border-radius: 0 0 5px 5px;"></div>
                            </div>
                        </div>
                    {% endif %}

                    <div class="mb-3">
                        <h5 class="text-muted mb-2">
                            <i class="bi bi-file-text-fill"></i> Description
                        </h5>
                        <p style="white-space: pre-wrap;">{{ offer.description }}</p>
                    </div>

                    {% if offer.requirements %}
                        <div class="mb-3">
                            <h5 class="text-muted mb-2">
                                <i class="bi bi-check-circle-fill"></i> Requirements
                            </h5>
                            <p style="white-space: pre-wrap;">{{ offer.requirements }}</p>
                        </div>
                    {% endif %}

                    {# ATS Detailed Requirements #}
                    {% if offer.minExperienceYears or offer.minEducation or offer.requiredLanguages|length > 0 %}
                        <div class="mb-3">
                            <h5 class="text-muted mb-2">
                                <i class="bi bi-person-workspace"></i> Detailed Requirements
                            </h5>
                            <div class="row">
                                {% if offer.minExperienceYears %}
                                    <div class="col-md-4 mb-2">
                                        <div class="p-3 bg-light rounded h-100">
                                            <h6 class="fw-bold mb-2">
                                                <i class="bi bi-briefcase text-primary"></i> Expérience minimum
                                            </h6>
                                            <p class="mb-0">{{ offer.minExperienceYears }} {{ offer.minExperienceYears > 1 ? 'années' : 'année' }}</p>
                                        </div>
                                    </div>
                                {% endif %}
                                {% if offer.minEducation %}
                                    <div class="col-md-4 mb-2">
                                        <div class="p-3 bg-light rounded h-100">
                                            <h6 class="fw-bold mb-2">
                                                <i class="bi bi-mortarboard text-success"></i> Niveau d'études minimum
                                            </h6>
                                            <p class="mb-0">{{ offer.minEducation }}</p>
                                        </div>
                                    </div>
                                {% endif %}
                                {% if offer.requiredLanguages|length > 0 %}
                                    <div class="col-md-4 mb-2">
                                        <div class="p-3 bg-light rounded h-100">
                                            <h6 class="fw-bold mb-2">
                                                <i class="bi bi-translate text-info"></i> Langues requises
                                            </h6>
                                            {% for language in offer.requiredLanguages %}
                                                <span class="badge bg-secondary me-1 mb-1">{{ language }}</span>
                                            {% endfor %}
                                        </div>
                                    </div>
                                {% endif %}
                            </div>
                        </div>
                    {% endif %}

                    <hr class="my-4">

                    <div class="row">
                        <div class="col-md-6">
                            <small class="text-muted">
                                <i class="bi bi-calendar-plus"></i> 
                                Created: {{ offer.createdAt|date('Y-m-d H:i') }}
                            </small>
                        </div>
                        {% if offer.publishedAt %}
                            <div class="col-md-6">
                                <small class="text-muted">
                                    <i class="bi bi-calendar-check"></i> 
                                    Published: {{ offer.publishedAt|date('Y-m-d H:i') }}
                                </small>
                            </div>
                        {% endif %}
                    </div>

                    {% if offer.expiresAt %}
                        <div class="mt-2">
                            <small class="text-muted">
                                <i class="bi bi-calendar-x"></i> 
                                Expires: {{ offer.expiresAt|date('Y-m-d H:i') }}
                            </small>
                        </div>
                    {% endif %}
                </div>
            </div>

            {# Application Section - Only for Students #}
            {% if is_granted('ROLE_STUDENT') %}
                <div class="card">
                    <div class="card-header">
                        <h4 class="mb-0">
                            <i class="bi bi-send-fill"></i> Apply for this Position
                        </h4>
                    </div>
                    <div class="card-body">
                        {% if alreadyApplied %}
                            {# Already Applied Alert #}
                            <div class="alert alert-warning" role="alert">
                                <h5 class="alert-heading">
                                    <i class="bi bi-exclamation-triangle"></i> Already Applied
                                </h5>
                                <p class="mb-0">You have already submitted an application for this job offer.</p>
                            </div>
                        {% elseif offer.status.value != 'ACTIVE' %}
                            {# Offer Not Active #}
                            <div class="alert alert-info" role="alert">
                                <h5 class="alert-heading">
                                    <i class="bi bi-info-circle"></i> Application Not Available
                                </h5>
                                <p class="mb-0">This job offer is no longer accepting applications.</p>
                            </div>
                        {% else %}
                            {# Application Form #}
                            {{ form_start(form, {'attr': {'enctype': 'multipart/form-data'}}) }}
                                <div class="mb-3">
                                    <div class="d-flex justify-content-between align-items-center mb-2">
                                        {{ form_label(form.message) }}
                                        <button type="button" id="btn-generate-motivation" class="btn btn-outline-info btn-sm"
                                                data-offer-id="{{ offer.id }}"
                                                data-textarea-id="{{ form.message.vars.id }}">
                                            <i class="bi bi-stars"></i> Generate with AI
                                        </button>
                                    </div>
                                    {{ form_widget(form.message, {'attr': {'rows': 10}}) }}
                                    {{ form_errors(form.message) }}
                                    <div id="ai-generation-status" class="mt-2" style="display:none;">
                                        <div class="d-flex align-items-center text-info">
                                            <div class="spinner-border spinner-border-sm me-2" role="status"></div>
                                            <span>Generating your motivation letter with AI...</span>
                                        </div>
                                    </div>
                                    <small class="text-muted d-block mt-1">
                                        <i class="bi bi-info-circle"></i> Click <strong>"Generate with AI"</strong> to create a personalized motivation letter based on your profile and this job offer. You can edit it afterwards.
                                    </small>
                                </div>

                                <div class="mb-3">
                                    {{ form_row(form.cvFile) }}
                                    <small class="text-muted">
                                        Maximum file size: 10MB. Allowed formats: PDF, DOC, DOCX
                                    </small>
                                </div>

                                <div class="d-grid gap-2">
                                    <button type="submit" class="btn btn-primary btn-lg">
                                        <i class="bi bi-send"></i> Apply for this Position
                                    </button>
                                </div>
                            {{ form_end(form) }}
                        {% endif %}
                    </div>
                </div>
            {% endif %}
        </div>
    </div>
</div>
{% endblock %}

{% block javascripts %}
{{ parent() }}
<script>
function initShowPage() {
    const btn = document.getElementById('btn-generate-motivation');
    if (!btn) return;

    btn.addEventListener('click', async function() {
        const offerId = this.dataset.offerId;
        const textareaId = this.dataset.textareaId;
        const textarea = document.getElementById(textareaId);
        const status = document.getElementById('ai-generation-status');

        if (!textarea) {
            console.error('Textarea not found with id:', textareaId);
            return;
        }

        // Confirm if textarea already has content
        if (textarea.value.trim().length > 0) {
            if (!confirm('This will replace your current text. Continue?')) return;
        }

        // Show loading state
        btn.disabled = true;
        btn.innerHTML = '<span class="spinner-border spinner-border-sm me-1"></span> Generating...';
        status.style.display = 'block';

        try {
            const response = await fetch('/job-offers/' + offerId + '/generate-motivation', {
                method: 'POST',
                headers: {
                    'X-Requested-With': 'XMLHttpRequest',
                }
            });

            const data = await response.json();

            if (data.success && data.letter) {
                textarea.value = data.letter;
                textarea.style.height = 'auto';
                textarea.style.height = textarea.scrollHeight + 'px';
                status.innerHTML = '<div class="text-success"><i class="bi bi-check-circle"></i> Motivation letter generated! Feel free to edit it before submitting.</div>';
            } else {
                status.innerHTML = '<div class="text-danger"><i class="bi bi-exclamation-triangle"></i> ' + (data.error || 'Failed to generate. Please try again.') + '</div>';
            }
        } catch (err) {
            status.innerHTML = '<div class="text-danger"><i class="bi bi-exclamation-triangle"></i> Network error. Please try again.</div>';
        } finally {
            btn.disabled = false;
            btn.innerHTML = '<i class="bi bi-stars"></i> Generate with AI';
            setTimeout(function() {
                status.style.display = 'none';
                status.innerHTML = '<div class="d-flex align-items-center text-info"><div class="spinner-border spinner-border-sm me-2" role="status"></div><span>Generating your motivation letter with AI...</span></div>';
            }, 5000);
        }
    });
}

// Turbo-compatible initialization
document.addEventListener('turbo:load', initShowPage);

// Load and initialize Leaflet map
document.addEventListener('turbo:load', function() {
    if (document.querySelector('#job-offer-map')) {
        initJobOfferMap();
    }
});

// ========== JOB OFFER MAP DISPLAY ==========

function initJobOfferMap() {
    // Leaflet CDN URLs
    const leafletCssUrl = 'https://cdnjs.cloudflare.com/ajax/libs/leaflet/1.9.4/leaflet.min.css';
    const leafletJsUrl = 'https://cdnjs.cloudflare.com/ajax/libs/leaflet/1.9.4/leaflet.min.js';

    // Load Leaflet CSS if not already loaded
    if (!document.querySelector(`link[href="${leafletCssUrl}"]`)) {
        const link = document.createElement('link');
        link.rel = 'stylesheet';
        link.href = leafletCssUrl;
        document.head.appendChild(link);
    }

    // Load Leaflet JS if not already loaded
    if (typeof L === 'undefined') {
        const script = document.createElement('script');
        script.src = leafletJsUrl;
        script.onload = () => {
            displayJobOfferMap();
        };
        document.head.appendChild(script);
    } else {
        displayJobOfferMap();
    }

    function displayJobOfferMap() {
        const mapContainer = document.querySelector('#job-offer-map');
        if (!mapContainer) return;

        // Get coordinates from data attributes
        const lat = parseFloat(mapContainer.dataset.jobLat);
        const lon = parseFloat(mapContainer.dataset.jobLon);

        // Make sure we have valid coordinates
        if (!lat || !lon || isNaN(lat) || isNaN(lon)) {
            console.warn('Invalid coordinates for job offer map');
            return;
        }

        // Initialize map
        const map = L.map(mapContainer).setView([lat, lon], 10);

        // Add OpenStreetMap tiles
        L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png', {
            attribution: '© OpenStreetMap contributors',
            maxZoom: 19,
        }).addTo(map);

        // Add marker for job location
        L.marker([lat, lon])
            .addTo(map)
            .bindPopup(`<strong>Job Location</strong><br>Coordinates: ${lat.toFixed(4)}, ${lon.toFixed(4)}`)
            .openPopup();
    }
}
</script>
{% endblock %}