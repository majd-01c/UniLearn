{% extends 'base.html.twig' %}

{% block title %}Candidatures - UniLearn{% endblock %}

{% block body %}
<div class="container mt-4">
    {# Flash Messages #}
    {% for label, messages in app.flashes %}
        {% for message in messages %}
            <div class="alert alert-{{ label == 'error' ? 'danger' : label }} alert-dismissible fade show" role="alert">
                {{ message }}
                <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
            </div>
        {% endfor %}
    {% endfor %}

    {# Back Button #}
    <div class="mb-3 d-flex justify-content-between align-items-center">
        <a href="{{ path('app_partner_job_offer_index') }}" class="btn btn-outline-secondary">
            <i class="bi bi-arrow-left"></i> Retour aux offres
        </a>
        
        {% if applications|length > 0 %}
        {# Bulk Score Button #}
        <form method="post" action="{{ path('app_partner_job_offer_calculate_all_scores', {id: offer.id}) }}" class="d-inline">
            <input type="hidden" name="_token" value="{{ csrf_token('calculate-all-' ~ offer.id) }}">
            <button type="submit" class="btn btn-info" onclick="return confirm('Calculer les scores ATS pour toutes les candidatures ?')">
                <i class="bi bi-calculator"></i> Calculer tous les scores ATS
            </button>
        </form>
        {% endif %}
    </div>

    {# Offer Information #}
    <div class="card mb-4">
        <div class="card-header bg-primary text-white">
            <h2 class="mb-0">
                <i class="bi bi-file-earmark-text-fill"></i> Candidatures: {{ offer.title }}
            </h2>
        </div>
        <div class="card-body">
            <div class="row">
                <div class="col-md-3">
                    <strong>Type:</strong> 
                    <span class="badge bg-info">{{ offer.type.value|replace({'_': ' '})|title }}</span>
                </div>
                <div class="col-md-3">
                    <strong>Statut:</strong> 
                    {% include 'Gestion_Job_Offre/job_offer/_offer_status_badge.html.twig' with {status: offer.status} only %}
                </div>
                <div class="col-md-3">
                    <strong>Candidatures:</strong> 
                    <span class="badge bg-primary">{{ applications|length }}</span>
                </div>
                <div class="col-md-3">
                    <strong>Compétences requises:</strong>
                    <span class="badge bg-secondary">{{ offer.requiredSkills|length }}</span>
                </div>
            </div>
            {% if offer.requiredSkills|length > 0 %}
            <div class="mt-2">
                <small class="text-muted">
                    <strong>Skills requis:</strong> {{ offer.requiredSkills|join(', ') }}
                </small>
            </div>
            {% endif %}
        </div>
    </div>

    {% if applications is empty %}
        {# No Applications #}
        <div class="card text-center py-5">
            <div class="card-body">
                <i class="bi bi-inbox text-muted" style="font-size: 4rem;"></i>
                <h3 class="mt-3">Aucune candidature</h3>
                <p class="text-muted">Cette offre n'a pas encore reçu de candidatures.</p>
            </div>
        </div>
    {% else %}
        {# Score Legend #}
        <div class="mb-3">
            <span class="badge bg-success">75+ Excellent</span>
            <span class="badge bg-warning text-dark">50-74 Moyen</span>
            <span class="badge bg-danger">0-49 Faible</span>
            <span class="badge bg-secondary">- Non calculé</span>
        </div>

        {# Applications Table #}
        <div class="card">
            <div class="card-body p-0">
                <div class="table-responsive">
                    <table class="table table-hover align-middle mb-0">
                        <thead>
                            <tr>
                                <th style="width: 80px;" class="ps-3">
                                    <a href="{{ path('app_partner_job_offer_applications', {id: offer.id, sort: 'score'}) }}" 
                                       class="text-decoration-none {{ currentSort|default('score') == 'score' ? 'fw-bold' : '' }}">
                                        Score <i class="bi bi-sort-down"></i>
                                    </a>
                                </th>
                                <th>Candidat</th>
                                <th>Compétences détectées</th>
                                <th style="width: 60px;">CV</th>
                                <th style="width: 90px;">Date</th>
                                <th style="width: 100px;">Statut</th>
                                <th style="width: 60px;" class="text-center">Actions</th>
                            </tr>
                        </thead>
                        <tbody>
                            {% for application in applications %}
                                <tr>
                                    {# Score Column #}
                                    <td class="ps-3">
                                        {% if application.score is not null %}
                                            {% set scoreClass = application.score >= 75 ? 'success' : (application.score >= 50 ? 'warning' : 'danger') %}
                                            <span class="badge bg-{{ scoreClass }} fs-6" style="min-width: 50px;">
                                                {{ application.score }}
                                            </span>
                                            <br>
                                            <a href="{{ path('app_partner_job_application_score_details', {id: application.id}) }}" 
                                               class="btn btn-sm btn-outline-{{ scoreClass }} mt-1" title="Voir les détails du score">
                                                <i class="bi bi-eye"></i> Détails
                                            </a>
                                        {% else %}
                                            <span class="badge bg-secondary">-</span>
                                            <br>
                                            <form method="post" action="{{ path('app_partner_job_application_calculate_score', {id: application.id}) }}" class="d-inline">
                                                <input type="hidden" name="_token" value="{{ csrf_token('score-' ~ application.id) }}">
                                                <button type="submit" class="btn btn-sm btn-link p-0" title="Calculer score">
                                                    <small><i class="bi bi-calculator"></i> Calculer</small>
                                                </button>
                                            </form>
                                        {% endif %}
                                    </td>
                                    
                                    {# Student Info #}
                                    <td>
                                        {% if application.student.profile %}
                                            <strong>{{ application.student.profile.fullName }}</strong><br>
                                            <small class="text-muted">
                                                <i class="bi bi-envelope"></i> {{ application.student.email }}
                                            </small>
                                        {% else %}
                                            <strong>{{ application.student.email }}</strong>
                                        {% endif %}
                                    </td>
                                    
                                    {# Extracted Skills #}
                                    <td>
                                        {% if application.extractedData and application.extractedData.skills|default([])|length > 0 %}
                                            {% for skill in application.extractedData.skills|slice(0, 5) %}
                                                {% set isMatched = skill in offer.requiredSkills %}
                                                <span class="badge bg-{{ isMatched ? 'success' : 'light text-dark' }} me-1 mb-1">
                                                    {{ skill }}
                                                </span>
                                            {% endfor %}
                                            {% if application.extractedData.skills|length > 5 %}
                                                <span class="badge bg-secondary">+{{ application.extractedData.skills|length - 5 }}</span>
                                            {% endif %}
                                        {% else %}
                                            <span class="text-muted">
                                                <small><i class="bi bi-question-circle"></i> Non analysé</small>
                                            </span>
                                        {% endif %}
                                    </td>
                                    
                                    {# CV Download #}
                                    <td>
                                        {% if application.cvFileName %}
                                            <a href="{{ vich_uploader_asset(application, 'cvFile') }}" 
                                               target="_blank" 
                                               class="btn btn-sm btn-outline-primary"
                                               download>
                                                <i class="bi bi-file-earmark-arrow-down"></i>
                                            </a>
                                        {% else %}
                                            <span class="text-muted">-</span>
                                        {% endif %}
                                    </td>
                                    
                                    {# Date #}
                                    <td>
                                        <small class="text-muted">
                                            {{ application.createdAt|date('d/m/Y') }}
                                        </small>
                                    </td>
                                    
                                    {# Status #}
                                    <td>
                                        {% include 'Gestion_Job_Offre/job_offer/_application_status_badge.html.twig' with {status: application.status} only %}
                                    </td>
                                    
                                    {# Actions Toggle #}
                                    <td class="text-center">
                                        <button class="btn btn-sm btn-outline-primary" type="button"
                                                data-bs-toggle="collapse" 
                                                data-bs-target="#action-panel-{{ application.id }}"
                                                aria-expanded="false"
                                                title="Gérer la candidature">
                                            <i class="bi bi-gear"></i>
                                        </button>
                                    </td>
                                </tr>

                                {# Expandable Action Panel #}
                                <tr class="collapse-row">
                                    <td colspan="7" class="p-0 border-0">
                                        <div class="collapse" id="action-panel-{{ application.id }}">
                                            <div class="p-3 m-2 rounded" style="background: var(--surface-elevated, #f8f9fa); border: 1px solid rgba(255,255,255,0.08);">
                                                <div class="row g-3">
                                                    {# Left: Status Update #}
                                                    <div class="col-md-4">
                                                        <h6 class="fw-bold mb-2">
                                                            <i class="bi bi-arrow-left-right text-primary"></i> Update Status
                                                        </h6>
                                                        <form method="post" action="{{ path('app_partner_job_application_status', {id: application.id}) }}" class="status-form">
                                                            <input type="hidden" name="_token" value="{{ csrf_token('status-' ~ application.id) }}">
                                                            
                                                            <div class="d-flex gap-1 flex-wrap mb-2">
                                                                <label class="btn btn-sm {{ application.status.value == 'REVIEWED' ? 'btn-info' : 'btn-outline-info' }}">
                                                                    <input type="radio" name="status" value="REVIEWED" class="btn-check status-radio" 
                                                                           data-app-id="{{ application.id }}"
                                                                           {{ application.status.value == 'REVIEWED' ? 'checked' : '' }} autocomplete="off">
                                                                    <i class="bi bi-eye"></i> Reviewed
                                                                </label>
                                                                <label class="btn btn-sm {{ application.status.value == 'ACCEPTED' ? 'btn-success' : 'btn-outline-success' }}">
                                                                    <input type="radio" name="status" value="ACCEPTED" class="btn-check status-radio"
                                                                           data-app-id="{{ application.id }}"
                                                                           {{ application.status.value == 'ACCEPTED' ? 'checked' : '' }} autocomplete="off">
                                                                    <i class="bi bi-check-circle"></i> Accept
                                                                </label>
                                                                <label class="btn btn-sm {{ application.status.value == 'REJECTED' ? 'btn-danger' : 'btn-outline-danger' }}">
                                                                    <input type="radio" name="status" value="REJECTED" class="btn-check status-radio"
                                                                           data-app-id="{{ application.id }}"
                                                                           {{ application.status.value == 'REJECTED' ? 'checked' : '' }} autocomplete="off">
                                                                    <i class="bi bi-x-circle"></i> Reject
                                                                </label>
                                                            </div>

                                                            <button type="submit" class="btn btn-primary btn-sm w-100">
                                                                <i class="bi bi-check-lg"></i> Confirm Update
                                                            </button>

                                                            {# Hidden message field - populated from the right panel #}
                                                            <input type="hidden" name="status_message" id="hidden-msg-{{ application.id }}" value="">
                                                        </form>
                                                    </div>

                                                    {# Right: Message to Candidate #}
                                                    <div class="col-md-8">
                                                        <div class="d-flex justify-content-between align-items-center mb-2">
                                                            <h6 class="fw-bold mb-0">
                                                                <i class="bi bi-chat-left-text text-info"></i> Message to Candidate
                                                            </h6>
                                                            <button type="button" class="btn btn-outline-info btn-sm btn-ai-msg"
                                                                    data-app-id="{{ application.id }}"
                                                                    title="Generate message with AI">
                                                                <i class="bi bi-stars"></i> Generate with AI
                                                            </button>
                                                        </div>
                                                        <textarea id="msg-textarea-{{ application.id }}" 
                                                                  class="form-control form-control-sm msg-textarea" rows="3"
                                                                  placeholder="Write a message to explain your decision..."
                                                                  maxlength="2000"
                                                                  data-app-id="{{ application.id }}">{{ application.statusMessage }}</textarea>
                                                        <div class="d-flex justify-content-between align-items-center mt-1">
                                                            <small class="text-muted">
                                                                <i class="bi bi-info-circle"></i> This message will be visible to the student.
                                                            </small>
                                                            <small id="ai-status-{{ application.id }}" class="text-info" style="display:none;">
                                                                <span class="spinner-border spinner-border-sm me-1"></span> Generating...
                                                            </small>
                                                        </div>
                                                    </div>
                                                </div>
                                            </div>
                                        </div>
                                    </td>
                                </tr>
                            {% endfor %}
                        </tbody>
                    </table>
                </div>
            </div>
        </div>

        <div class="mt-3 text-muted">
            <i class="bi bi-info-circle"></i> Total: {{ applications|length }} candidature(s)
        </div>
    {% endif %}
</div>
{% endblock %}

{% block javascripts %}
{{ parent() }}
<script>
function initApplicationsPage() {

    // Sync textarea content to hidden form field before submit
    document.querySelectorAll('.status-form').forEach(function(form) {
        form.addEventListener('submit', function() {
            var hiddenInput = form.querySelector('input[name="status_message"]');
            var appId = hiddenInput.id.replace('hidden-msg-', '');
            var textarea = document.getElementById('msg-textarea-' + appId);
            if (textarea) {
                hiddenInput.value = textarea.value;
            }
        });
    });

    // Update radio button visual styles on change
    document.querySelectorAll('.status-radio').forEach(function(radio) {
        radio.addEventListener('change', function() {
            var form = this.closest('form');
            form.querySelectorAll('.status-radio').forEach(function(r) {
                var label = r.closest('label');
                var cls = label.className;
                // Reset to outline variant
                label.className = cls.replace(/btn-(info|success|danger)\b/g, function(match) {
                    return 'btn-outline-' + match.replace('btn-', '');
                });
            });
            // Activate selected
            var myLabel = this.closest('label');
            myLabel.className = myLabel.className.replace(/btn-outline-(info|success|danger)\b/, function(match) {
                return match.replace('btn-outline-', 'btn-');
            });
        });
    });

    // AI Generate Message
    document.querySelectorAll('.btn-ai-msg').forEach(function(btn) {
        btn.addEventListener('click', async function() {
            var appId = this.dataset.appId;
            var textarea = document.getElementById('msg-textarea-' + appId);
            var aiStatus = document.getElementById('ai-status-' + appId);
            var form = document.querySelector('#action-panel-' + appId + ' .status-form');
            
            // Get selected decision
            var selectedRadio = form ? form.querySelector('.status-radio:checked') : null;
            var decision = selectedRadio ? selectedRadio.value : null;

            if (!decision || (decision !== 'ACCEPTED' && decision !== 'REJECTED')) {
                alert('Please select Accept or Reject first before generating a message.');
                return;
            }

            // Confirm overwrite
            if (textarea.value.trim().length > 0) {
                if (!confirm('This will replace the current message. Continue?')) return;
            }

            // Loading state
            btn.disabled = true;
            btn.innerHTML = '<span class="spinner-border spinner-border-sm"></span>';
            aiStatus.style.display = 'inline';

            try {
                var formData = new FormData();
                formData.append('decision', decision);

                var response = await fetch('/partner/job-applications/' + appId + '/generate-message', {
                    method: 'POST',
                    body: formData,
                });

                var data = await response.json();

                if (data.success && data.message) {
                    textarea.value = data.message;
                    textarea.style.height = 'auto';
                    textarea.style.height = textarea.scrollHeight + 'px';
                    aiStatus.innerHTML = '<i class="bi bi-check-circle text-success"></i> Done!';
                } else {
                    aiStatus.innerHTML = '<i class="bi bi-exclamation-triangle text-danger"></i> ' + (data.error || 'Failed');
                }
            } catch (err) {
                aiStatus.innerHTML = '<i class="bi bi-exclamation-triangle text-danger"></i> Network error';
            } finally {
                btn.disabled = false;
                btn.innerHTML = '<i class="bi bi-stars"></i> Generate with AI';
                setTimeout(function() { aiStatus.style.display = 'none'; aiStatus.innerHTML = '<span class="spinner-border spinner-border-sm me-1"></span> Generating...'; }, 4000);
            }
        });
    });
}

// Turbo-compatible initialization
document.addEventListener('turbo:load', initApplicationsPage);
</script>
{% endblock %}
