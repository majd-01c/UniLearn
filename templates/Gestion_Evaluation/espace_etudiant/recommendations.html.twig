{% extends 'base.html.twig' %}

{% block title %}AI Recommendations{% endblock %}

{% block body %}
<div class="container-fluid mt-4 px-4 animate-in">
    <div class="uni-page-header">
        <div class="uni-page-header-info">
            <h1 class="uni-page-header-title">
                <i class="bi bi-robot"></i> AI Assistant - Personalized Recommendations
            </h1>
            <p class="uni-page-header-subtitle">Improve your academic performance with AI</p>
        </div>
        <div class="uni-page-header-actions">
            <a href="{{ path('app_espace_etudiant_results') }}" class="btn btn-primary btn-sm">
                <i class="bi bi-bar-chart-fill"></i> My Results
            </a>
        </div>
    </div>
    
    <div class="alert alert-info border-primary mb-4" style="border-left: 5px solid #0d6efd;">
        <div class="d-flex align-items-start">
            <i class="bi bi-info-circle-fill me-3" style="font-size: 1.5rem;"></i>
            <div>
                <h5 class="alert-heading">How does the AI work?</h5>
                <p class="mb-0">Our AI system analyzes your academic performance in real time and identifies areas that need improvement. It then suggests quality online courses, specifically selected to help you progress.</p>
            </div>
        </div>
    </div>
    
    {% if recommendations|length > 0 %}
    <div class="row g-4 stagger-in">
        {% for recommendation in recommendations %}
        <div class="col-12">
            <div class="card shadow-sm border-{% if recommendation.priority == 'HIGH' %}danger{% elseif recommendation.priority == 'MEDIUM' %}warning{% else %}info{% endif %}" style="border-left: 5px solid;">
                <div class="card-header bg-{% if recommendation.priority == 'HIGH' %}danger{% elseif recommendation.priority == 'MEDIUM' %}warning{% else %}info{% endif %} bg-opacity-10">
                    <div class="d-flex justify-content-between align-items-center">
                        <h5 class="mb-0 fw-bold">
                            <i class="bi bi-book-fill"></i> {{ recommendation.courseName }}
                        </h5>
                        <span class="badge bg-{% if recommendation.priority == 'HIGH' %}danger{% elseif recommendation.priority == 'MEDIUM' %}warning{% else %}info{% endif %}">
                            <i class="bi bi-{% if recommendation.priority == 'HIGH' %}exclamation-triangle-fill{% elseif recommendation.priority == 'MEDIUM' %}dash-circle-fill{% else %}info-circle-fill{% endif %}"></i>
                            Priority {{ recommendation.priority }}
                        </span>
                    </div>
                </div>
                <div class="card-body">
                    <div class="row">
                        <div class="col-md-4 border-end">
                            <h6 class="text-muted mb-3">
                                <i class="bi bi-graph-down"></i> Current Performance
                            </h6>
                            <div class="text-center mb-3">
                                <div class="display-3 fw-bold text-{% if recommendation.average < 8 %}danger{% elseif recommendation.average < 10 %}warning{% else %}info{% endif %}">
                                    {{ recommendation.average }}/20
                                </div>
                                <p class="text-muted fw-semibold">{{ recommendation.status }}</p>
                            </div>
                            
                            {% if recommendation.aiInsight %}
                            <div class="alert alert-light border mt-3">
                                <small class="d-flex align-items-start">
                                    <i class="bi bi-lightbulb-fill text-warning me-2 mt-1"></i>
                                    <span><strong>AI:</strong> {{ recommendation.aiInsight }}</span>
                                </small>
                            </div>
                            {% endif %}
                        </div>
                        <div class="col-md-8">
                                <h6 class="text-muted mb-3">
                                <i class="bi bi-stars"></i> AI-Recommended Online Courses
                            </h6>
                            <div class="list-group">
                                {% for courseName, courseUrl in recommendation.recommendedCourses %}
                                <a href="{{ courseUrl }}" target="_blank" class="list-group-item list-group-item-action hover-lift">
                                    <div class="d-flex w-100 justify-content-between align-items-center">
                                        <div>
                                            <h6 class="mb-1 fw-semibold">
                                                <i class="bi bi-mortarboard-fill text-primary"></i> {{ courseName }}
                                            </h6>
                                            <small class="text-muted">{{ courseUrl }}</small>
                                        </div>
                                        <i class="bi bi-box-arrow-up-right text-primary"></i>
                                    </div>
                                </a>
                                {% endfor %}
                            </div>

                            {% if recommendation.youtubeVideos|length > 0 %}
                            <hr class="my-3">
                            <h6 class="text-muted mb-3">
                                <i class="bi bi-youtube text-danger"></i> Recommended YouTube Videos
                            </h6>
                            <div class="row g-2">
                                {% for video in recommendation.youtubeVideos %}
                                <div class="col-md-6">
                                    <a href="{{ video.url }}" target="_blank" class="text-decoration-none">
                                        <div class="card border-0 bg-light hover-lift h-100">
                                            <div class="card-body p-3">
                                                <div class="d-flex align-items-start gap-2">
                                                    <div class="flex-shrink-0">
                                                        <div class="rounded-circle bg-danger d-flex align-items-center justify-content-center" style="width:36px;height:36px">
                                                            <i class="bi bi-play-fill text-white"></i>
                                                        </div>
                                                    </div>
                                                    <div>
                                                        <p class="mb-0 fw-semibold text-dark small">{{ video.title }}</p>
                                                        <small class="text-muted"><i class="bi bi-person-fill"></i> {{ video.channel }}</small>
                                                        {% if video.description is defined %}
                                                        <br><small class="text-muted fst-italic">{{ video.description }}</small>
                                                        {% endif %}
                                                    </div>
                                                </div>
                                            </div>
                                        </div>
                                    </a>
                                </div>
                                {% endfor %}
                            </div>
                            {% endif %}

                            <div class="mt-4 p-3 bg-light rounded">
                                <h6 class="mb-2">
                                    <i class="bi bi-bullseye text-success"></i> Recommended Goal
                                </h6>
                                <p class="text-muted mb-0 small">
                                    Aim to reach at least <strong>12/20</strong> in this subject by following the recommended courses and practicing regularly. The AI will adapt its recommendations based on your progress.
                                </p>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
        {% endfor %}
    </div>
    
    <!-- AI-Powered Learning Tips -->
    <div class="card mt-4 border-success" style="border-left: 5px solid #198754;">
        <div class="card-header bg-success bg-opacity-10">
            <h5 class="mb-0">
                <i class="bi bi-robot text-success"></i> AI Tips to Maximize Your Results
            </h5>
        </div>
        <div class="card-body">
            <div class="row g-3">
                <div class="col-md-6">
                    <div class="d-flex align-items-start">
                        <i class="bi bi-calendar-check-fill text-primary me-3 fs-4"></i>
                        <div>
                            <h6 class="fw-bold">Consistency</h6>
                            <small class="text-muted">Dedicate 30-60 minutes daily to recommended courses rather than long, infrequent sessions.</small>
                        </div>
                    </div>
                </div>
                <div class="col-md-6">
                    <div class="d-flex align-items-start">
                        <i class="bi bi-journal-text text-success me-3 fs-4"></i>
                        <div>
                            <h6 class="fw-bold">Active Practice</h6>
                            <small class="text-muted">Do additional exercises and test your knowledge regularly.</small>
                        </div>
                    </div>
                </div>
                <div class="col-md-6">
                    <div class="d-flex align-items-start">
                        <i class="bi bi-people-fill text-info me-3 fs-4"></i>
                        <div>
                            <h6 class="fw-bold">Collaboration</h6>
                            <small class="text-muted">Join study groups and discuss with your professors.</small>
                        </div>
                    </div>
                </div>
                <div class="col-md-6">
                    <div class="d-flex align-items-start">
                        <i class="bi bi-graph-up-arrow text-warning me-3 fs-4"></i>
                        <div>
                            <h6 class="fw-bold">Track Progress</h6>
                            <small class="text-muted">Check your results regularly to measure the effectiveness of your learning.</small>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
    
    {% else %}
    <div class="card border-success" style="border-left: 5px solid #198754;">
        <div class="card-body text-center py-5">
            <i class="bi bi-trophy-fill text-success" style="font-size: 4rem;"></i>
            <h3 class="mt-4 fw-bold">Congratulations! 🎉</h3>
            <p class="lead text-muted">You currently have no courses requiring improvement.</p>
            <hr class="my-4" style="width: 100px; margin: auto;">
            <p class="text-muted">
                Keep up the excellent work! The AI will continue to monitor your performance and alert you if any areas need attention.
            </p>
            <a href="{{ path('app_espace_etudiant_results') }}" class="btn btn-success mt-3">
                <i class="bi bi-bar-chart-fill"></i> View all my results
            </a>
        </div>
    </div>
    {% endif %}
    
    <div class="mt-4">
        <a href="{{ path('app_espace_etudiant_dashboard') }}" class="btn btn-outline-secondary">
            <i class="bi bi-arrow-left"></i> Back to Dashboard
        </a>
    </div>
</div>

<style>
.hover-lift {
    transition: transform 0.2s ease, box-shadow 0.2s ease;
}
.hover-lift:hover {
    transform: translateY(-2px);
    box-shadow: 0 4px 8px rgba(0,0,0,0.1);
}
</style>
{% endblock %}
