{% extends 'base.html.twig' %}

{% block title %}Edit Class - {{ classe.name }} - UniLearn{% endblock %}

{% block body %}
<div class="container-fluid py-4">
    <div class="row justify-content-center">
        <div class="col-lg-8">
            <div class="d-flex align-items-center mb-4">
                <a href="{{ path('app_classe_show', {id: classe.id}) }}" class="btn btn-outline-secondary me-3">
                    <i class="bi bi-arrow-left"></i>
                </a>
                <div>
                    <h1 class="h3 mb-0"><i class="bi bi-pencil-square text-warning"></i> Edit Class</h1>
                    <p class="text-muted mb-0">Modify {{ classe.name }}</p>
                </div>
            </div>

            <div class="card card-elevated">
                <div class="card-body p-4">
                    {{ form_start(form, {'attr': {'class': 'needs-validation', 'novalidate': 'novalidate', 'enctype': 'multipart/form-data'}}) }}
                    
                    <div class="row g-3">
                        <div class="col-12">
                            <label class="form-label fw-semibold">Class Name</label>
                            {{ form_widget(form.name) }}
                            {{ form_errors(form.name) }}
                        </div>

                        <div class="col-md-12">
                            <label class="form-label fw-semibold">Program</label>
                            {{ form_widget(form.program) }}
                            {{ form_errors(form.program) }}
                            <div class="form-text">The program this class belongs to</div>
                        </div>

                        <div class="col-md-6">
                            <label class="form-label fw-semibold">Level</label>
                            {{ form_widget(form.level) }}
                            {{ form_errors(form.level) }}
                        </div>

                        <div class="col-md-6">
                            <label class="form-label fw-semibold">Specialty</label>
                            {{ form_widget(form.specialty) }}
                            {{ form_errors(form.specialty) }}
                        </div>

                        <div class="col-md-6">
                            <label class="form-label fw-semibold">Maximum Capacity</label>
                            {{ form_widget(form.capacity) }}
                            {{ form_errors(form.capacity) }}
                            <div class="form-text">Currently {{ classe.studentCount }} students enrolled</div>
                        </div>

                        <div class="col-md-6">
                            <label class="form-label fw-semibold">Status</label>
                            {{ form_widget(form.status) }}
                            {{ form_errors(form.status) }}
                        </div>

                        <div class="col-md-6">
                            <label class="form-label fw-semibold">Start Date</label>
                            {{ form_widget(form.startDate) }}
                            {{ form_errors(form.startDate) }}
                        </div>

                        <div class="col-md-6">
                            <label class="form-label fw-semibold">End Date</label>
                            {{ form_widget(form.endDate) }}
                            {{ form_errors(form.endDate) }}
                        </div>

                        <div class="col-12">
                            <label class="form-label fw-semibold">Class Image (optional)</label>
                            {{ form_widget(form.imageFile) }}
                            {{ form_errors(form.imageFile) }}
                            <div class="drop-zone" id="dropZone" onclick="document.getElementById('classe_imageFile').click()">
                                <div class="drop-zone-content" id="dropZoneContent" {% if classe.imageFilename %}style="display:none"{% endif %}>
                                    <i class="bi bi-cloud-arrow-up" style="font-size: 2.5rem; color: #6c757d;"></i>
                                    <p class="mb-1 fw-semibold">Drag & drop an image here</p>
                                    <p class="text-muted small mb-0">or click to browse (JPEG, PNG, GIF, WebP — max 5MB)</p>
                                </div>
                                <img id="imagePreview" 
                                     src="{% if classe.imageFilename %}{{ asset('uploads/classes/' ~ classe.imageFilename) }}{% endif %}" 
                                     alt="Preview" 
                                     style="{% if not classe.imageFilename %}display:none;{% endif %} max-height: 200px; max-width: 100%; border-radius: 8px;">
                            </div>
                            {% if classe.imageFilename %}
                                <div class="form-text text-muted mt-1">
                                    <i class="bi bi-image"></i> Current image: {{ classe.imageFilename }} — upload a new file to replace it
                                </div>
                            {% endif %}
                        </div>
                    </div>

                    <hr class="my-4">

                    <div class="d-flex justify-content-between">
                        <div>
                            {# Delete button will trigger the separate delete form below #}
                            <button type="button" class="btn btn-outline-danger" 
                                    onclick="if(confirm('Are you sure you want to delete this class? All student enrollments will be removed.')) document.getElementById('delete-form').submit();">
                                <i class="bi bi-trash"></i> Delete Class
                            </button>
                        </div>

                        <div class="d-flex gap-2">
                            <a href="{{ path('app_classe_show', {id: classe.id}) }}" class="btn btn-outline-secondary">
                                <i class="bi bi-x-circle"></i> Cancel
                            </a>
                            <button type="submit" class="btn btn-warning">
                                <i class="bi bi-check-circle"></i> Save Changes
                            </button>
                        </div>
                    </div>
                    
                    {{ form_end(form) }}
                </div>
            </div>
        </div>
    </div>
</div>

{# Separate delete form outside the main edit form #}
<form id="delete-form" action="{{ path('app_classe_delete', {id: classe.id}) }}" method="post" style="display: none;">
    <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ classe.id) }}">
</form>

<style>
.drop-zone {
    border: 2px dashed #adb5bd;
    border-radius: 12px;
    padding: 30px;
    text-align: center;
    cursor: pointer;
    transition: all 0.3s ease;
    background: #f8f9fa;
    min-height: 160px;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
}
.drop-zone:hover, .drop-zone.drag-over {
    border-color: #ffc107;
    background: #fff8e1;
    box-shadow: 0 0 0 4px rgba(255,193,7,0.15);
}
.drop-zone.drag-over {
    transform: scale(1.01);
}
</style>

<script>
document.addEventListener('DOMContentLoaded', function() {
    const dropZone = document.getElementById('dropZone');
    const fileInput = document.getElementById('classe_imageFile');
    const preview = document.getElementById('imagePreview');
    const content = document.getElementById('dropZoneContent');

    ['dragenter', 'dragover'].forEach(evt => {
        dropZone.addEventListener(evt, e => { e.preventDefault(); dropZone.classList.add('drag-over'); });
    });
    ['dragleave', 'drop'].forEach(evt => {
        dropZone.addEventListener(evt, e => { e.preventDefault(); dropZone.classList.remove('drag-over'); });
    });

    dropZone.addEventListener('drop', function(e) {
        const files = e.dataTransfer.files;
        if (files.length > 0 && files[0].type.startsWith('image/')) {
            fileInput.files = files;
            showPreview(files[0]);
        }
    });

    fileInput.addEventListener('change', function() {
        if (this.files.length > 0) {
            showPreview(this.files[0]);
        }
    });

    function showPreview(file) {
        const reader = new FileReader();
        reader.onload = function(e) {
            preview.src = e.target.result;
            preview.style.display = 'block';
            content.style.display = 'none';
        };
        reader.readAsDataURL(file);
    }
});
</script>
{% endblock %}
