{% extends 'base.html.twig' %}

{% block title %}My Document Requests{% endblock %}

{% block body %}
<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h1><i class="fas fa-file-alt"></i> My Document Requests</h1>
        <a href="{{ path('app_espace_etudiant_document_request') }}" class="btn btn-primary">
            <i class="fas fa-plus"></i> New Request
        </a>
    </div>
    
    {% if documentRequests|length > 0 %}
    <div class="card">
        <div class="card-body">
            <div class="table-responsive">
                <table class="table table-hover">
                    <thead class="table-dark">
                        <tr>
                            <th>Document Type</th>
                            <th>Request Date</th>
                            <th>Status</th>
                            <th>Delivery Date</th>
                            <th>Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        {% for request in documentRequests %}
                        <tr>
                            <td>
                                <strong>
                                    {% if request.documentType == 'attestation_stage' %}
                                        Internship Certificate
                                    {% elseif request.documentType == 'attestation_inscription' %}
                                        Enrollment Certificate
                                    {% elseif request.documentType == 'releve_notes' %}
                                        Transcript
                                    {% elseif request.documentType == 'attestation_reussite' %}
                                        Certificate of Achievement
                                    {% elseif request.documentType == 'certificat_scolarite' %}
                                        Student Status Certificate
                                    {% else %}
                                        {{ request.documentType }}
                                    {% endif %}
                                </strong>
                                {% if request.additionalInfo %}
                                    <br><small class="text-muted">{{ request.additionalInfo }}</small>
                                {% endif %}
                            </td>
                            <td>{{ request.requestedAt|date('d/m/Y H:i') }}</td>
                            <td>
                                <span class="badge 
                                    {% if request.status == 'pending' %}bg-warning
                                    {% elseif request.status == 'approved' %}bg-info
                                    {% elseif request.status == 'ready' %}bg-success
                                    {% elseif request.status == 'delivered' %}bg-primary
                                    {% else %}bg-danger{% endif %}">
                                    {% if request.status == 'pending' %}Pending
                                    {% elseif request.status == 'approved' %}Approved
                                    {% elseif request.status == 'ready' %}Ready
                                    {% elseif request.status == 'delivered' %}Delivered
                                    {% else %}Rejected{% endif %}
                                </span>
                            </td>
                            <td>
                                {% if request.deliveredAt %}
                                    {{ request.deliveredAt|date('d/m/Y H:i') }}
                                {% else %}
                                    <span class="text-muted">-</span>
                                {% endif %}
                            </td>
                            <td>
    {% if request.documentPath %}
        <a href="{{ path('app_espace_etudiant_document_download', {id: request.id}) }}" class="btn btn-sm btn-success">
            <i class="fas fa-download"></i> Download
        </a>
    {% elseif request.status == 'pending' %}
        <span class="badge bg-warning">
            <i class="fas fa-clock"></i> Pending
        </span>
    {% elseif request.status == 'approved' %}
        <span class="badge bg-info">
            <i class="fas fa-spinner"></i> In Progress
        </span>
    {% elseif request.status == 'ready' %}
        <span class="badge bg-secondary">
            <i class="fas fa-exclamation-circle"></i> Coming Soon
        </span>
    {% else %}
        <span class="text-muted">Not Available</span>
    {% endif %}
    <button class="btn btn-sm btn-outline-secondary ms-1"
            data-doc-id="{{ request.id }}"
            data-doc-type="{{ request.documentType }}"
            data-req-date="{{ request.requestedAt|date('d/m/Y H:i') }}"
            data-status="{{ request.status }}"
            data-info="{{ request.additionalInfo|default('')|e('html_attr') }}"
            onclick="downloadReceipt(this)"
            title="Download request receipt">
        <i class="fas fa-file-pdf"></i> Receipt
    </button>
</td>

                        </tr>
                        {% endfor %}
                    </tbody>
                </table>
            </div>
        </div>
    </div>
    {% else %}
    <div class="alert alert-info">
        <i class="fas fa-info-circle"></i> You have no document requests yet.
    </div>
    {% endif %}
    
    <div class="card mt-4 bg-light">
        <div class="card-body">
            <h5><i class="fas fa-info-circle"></i> Information on Document Requests</h5>
            <ul class="mb-0">
                <li><strong>Processing time:</strong> 3-5 business days</li>
                <li><strong>Notification:</strong> You will receive an email when your document is ready</li>
                <li><strong>Validity:</strong> Documents are valid for 3 months</li>
                <li><strong>Questions:</strong> Contact the registrar's office for any inquiries</li>
            </ul>
        </div>
    </div>
    
    <div class="mt-4">
        <a href="{{ path('app_espace_etudiant_dashboard') }}" class="btn btn-secondary">
            <i class="fas fa-arrow-left"></i> Back to Dashboard
        </a>
    </div>
</div>
{% endblock %}

{% block javascripts %}
{{ parent() }}
<script src="/js/jspdf.umd.min.js"></script>
<script>
const DOCTYPE_LABELS = {
    'attestation_stage':      'Internship Certificate',
    'attestation_inscription':'Enrollment Certificate',
    'releve_notes':           'Transcript',
    'attestation_reussite':   'Certificate of Achievement',
    'certificat_scolarite':   'Student Status Certificate',
    'autre':                  'Other'
};
const STATUS_LABELS = {
    'pending':   'Pending',
    'approved':  'Approved',
    'ready':     'Ready',
    'delivered': 'Delivered',
    'rejected':  'Rejected'
};

function downloadReceipt(btn) {
    const docType   = DOCTYPE_LABELS[btn.dataset.docType] || btn.dataset.docType;
    const reqDate   = btn.dataset.reqDate;
    const status    = STATUS_LABELS[btn.dataset.status] || btn.dataset.status;
    const addInfo   = btn.dataset.info || '—';
    const reqId     = btn.dataset.docId;
    const studentName = '{{ app.user.name ?? app.user.email }}';

    const { jsPDF } = window.jspdf;
    const pdf = new jsPDF({ unit: 'mm', format: 'a4' });

    const blue  = [30, 78, 216];
    const gray  = [100, 100, 100];
    const black = [30, 30, 30];

    // Header bar
    pdf.setFillColor(...blue);
    pdf.rect(0, 0, 210, 28, 'F');
    pdf.setTextColor(255, 255, 255);
    pdf.setFontSize(18);
    pdf.text('UniLearn — Document Request Receipt', 105, 12, { align: 'center' });
    pdf.setFontSize(10);
    pdf.text('Student Academic Portal', 105, 20, { align: 'center' });

    // Body
    pdf.setTextColor(...black);
    let y = 40;

    function row(label, value) {
        pdf.setFontSize(10);
        pdf.setTextColor(...gray);
        pdf.text(label, 20, y);
        pdf.setTextColor(...black);
        pdf.setFontSize(11);
        pdf.text(String(value), 80, y);
        y += 9;
    }

    pdf.setFontSize(13);
    pdf.setFont(undefined, 'bold');
    pdf.text('Request Details', 20, y);
    pdf.setFont(undefined, 'normal');
    y += 8;
    pdf.setDrawColor(...blue);
    pdf.line(20, y, 190, y);
    y += 8;

    row('Request ID:', '#' + reqId);
    row('Student:', studentName);
    row('Document Type:', docType);
    row('Request Date:', reqDate);
    row('Current Status:', status);
    if (addInfo && addInfo !== '—') {
        row('Additional Info:', addInfo);
    }

    y += 6;
    pdf.setFillColor(240, 245, 255);
    pdf.roundedRect(20, y, 170, 18, 3, 3, 'F');
    pdf.setFontSize(9);
    pdf.setTextColor(...gray);
    pdf.text('Processing time: 3-5 business days. You will be notified by email when ready.', 105, y + 7, { align: 'center' });
    pdf.text('Documents are valid for 3 months from the delivery date.', 105, y + 13, { align: 'center' });

    y += 28;
    pdf.setDrawColor(200, 200, 200);
    pdf.line(20, y, 190, y);
    pdf.setFontSize(8);
    pdf.setTextColor(...gray);
    pdf.text('Generated on ' + new Date().toLocaleString() + ' — UniLearn Academic Portal', 105, y + 6, { align: 'center' });

    pdf.save('document-request-' + reqId + '.pdf');
}
</script>
{% endblock %}
