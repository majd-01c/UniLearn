{% extends 'base.html.twig' %}

{% block title %}Complaint Management{% endblock %}

{% block body %}
<div class="container-fluid mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h1><i class="bi bi-exclamation-circle"></i> Complaint Management</h1>
    </div>

    <div class="card">
        <div class="card-body">
            <div class="table-responsive">
                <table class="table table-hover">
                    <thead class="table-dark">
                        <tr>
                            <th>ID</th>
                            <th>Student</th>
                            <th>Subject</th>
                            <th>Course</th>
                            <th>Status</th>
                            <th>Date</th>
                            <th>Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        {% for reclamation in reclamations %}
                        <tr>
                            <td>{{ reclamation.id }}</td>
                            <td>{{ reclamation.student.name ?? reclamation.student.email }}</td>
                            <td>{{ reclamation.subject }}</td>
                            <td>{{ reclamation.relatedCourse ? reclamation.relatedCourse.title : '-' }}</td>
                            <td>
                                <span class="badge 
                                    {% if reclamation.status == 'pending' %}bg-warning
                                    {% elseif reclamation.status == 'in_progress' %}bg-info
                                    {% elseif reclamation.status == 'resolved' %}bg-success
                                    {% else %}bg-danger{% endif %}">
                                    {% if reclamation.status == 'pending' %}Pending
                                    {% elseif reclamation.status == 'in_progress' %}In Progress
                                    {% elseif reclamation.status == 'resolved' %}Resolved
                                    {% else %}Rejected{% endif %}
                                </span>
                            </td>
                            <td>{{ reclamation.createdAt|date('d/m/Y H:i') }}</td>
                            <td>
                                <a href="{{ path('app_admin_reclamation_show', {id: reclamation.id}) }}" class="btn btn-sm btn-primary">
                                    <i class="bi bi-eye"></i> View
                                </a>
                            </td>
                        </tr>
                        {% else %}
                        <tr>
                            <td colspan="7" class="text-center text-muted">No complaints found</td>
                        </tr>
                        {% endfor %}
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>
{% endblock %}
