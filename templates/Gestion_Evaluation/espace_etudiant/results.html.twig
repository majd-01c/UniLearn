{% extends 'base.html.twig' %}

{% block title %}Semester Results{% endblock %}

{% block body %}
<div class="container-fluid mt-4 px-4 animate-in">
    <div class="uni-page-header">
        <div class="uni-page-header-info">
            <h1 class="uni-page-header-title"><i class="bi bi-trophy-fill"></i> Semester Results</h1>
            <p class="uni-page-header-subtitle">Summary of your averages by course</p>
        </div>
        <div class="uni-page-header-actions">
            <a href="{{ path('app_espace_etudiant_grades') }}" class="btn btn-outline-primary btn-sm">
                <i class="bi bi-list-ol"></i> View detailed grades
            </a>
        </div>
    </div>

    <!-- Overall Summary -->
    <div class="row mb-4">
        <div class="col-md-12">
            <div class="card border-primary">
                <div class="card-header bg-primary text-white">
                    <h4 class="mb-0">Overall Summary</h4>
                </div>
                <div class="card-body">
                    <div class="row text-center">
                        <div class="col-md-3">
                            <h2 class="text-primary">{{ results.overallAverage }}/20</h2>
                            <p class="text-muted">Overall Average</p>
                        </div>
                        <div class="col-md-3">
                            <h2 class="text-success">{{ results.passedCourses }}</h2>
                            <p class="text-muted">Passed Courses</p>
                        </div>
                        <div class="col-md-3">
                            <h2 class="text-danger">{{ results.failedCourses }}</h2>
                            <p class="text-muted">Failed Courses</p>
                        </div>
                        <div class="col-md-3">
                            <h2 class="text-info">{{ results.courses|length }}</h2>
                            <p class="text-muted">Total Courses</p>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
    
    <!-- Detailed Results by Course -->
    <div class="row">
        <div class="col-md-12">
            <div class="card">
                <div class="card-header">
                    <h5>Details by Course</h5>
                </div>
                <div class="card-body">
                    {% if results.courses|length > 0 %}
                    <div class="accordion" id="coursesAccordion">
                        {% for courseName, courseData in results.courses %}
                        <div class="accordion-item">
                            <h2 class="accordion-header" id="heading{{ loop.index }}">
                                <button class="accordion-button {% if loop.index > 1 %}collapsed{% endif %}" type="button" data-bs-toggle="collapse" data-bs-target="#collapse{{ loop.index }}" aria-expanded="{% if loop.index == 1 %}true{% else %}false{% endif %}" aria-controls="collapse{{ loop.index }}">
                                    <strong>{{ courseData.name }}</strong>
                                    <span class="ms-3 badge {% if courseData.status == 'Passed' %}bg-success{% else %}bg-danger{% endif %}">
                                        {{ courseData.average }}/20 - {{ courseData.status }}
                                    </span>
                                </button>
                            </h2>
                            <div id="collapse{{ loop.index }}" class="accordion-collapse collapse {% if loop.index == 1 %}show{% endif %}" aria-labelledby="heading{{ loop.index }}" data-bs-parent="#coursesAccordion">
                                <div class="accordion-body">
                                    <div class="table-responsive">
                                        <table class="table table-sm">
                                            <thead>
                                                <tr>
                                                    <th>Assessment</th>
                                                    <th>Grade</th>
                                                    <th>Progress</th>
                                                    <th>Status</th>
                                                </tr>
                                            </thead>
                                            <tbody>
                                                {% for grade in courseData.grades %}
                                                <tr>
                                                    <td>{{ grade.assessment }}</td>
                                                    <td>{{ grade.score }}/{{ grade.maxScore }}</td>
                                                    <td>
                                                        <div class="progress progress-labeled" style="min-width:80px">
                                                            <div class="progress-bar {% if grade.percentage >= 60 %}bg-success{% elseif grade.percentage >= 50 %}bg-warning{% else %}bg-danger{% endif %}"
                                                                 role="progressbar" style="width: {{ grade.percentage }}%">
                                                                {{ grade.percentage|round(1) }}%
                                                            </div>
                                                        </div>
                                                    </td>
                                                    <td>
                                                        {% if grade.percentage >= 50 %}
                                                            <span class="badge bg-success"><i class="bi bi-check-circle-fill"></i> Passed</span>
                                                        {% else %}
                                                            <span class="badge bg-danger"><i class="bi bi-x-circle-fill"></i> Failed</span>
                                                        {% endif %}
                                                    </td>
                                                </tr>
                                                {% endfor %}
                                            </tbody>
                                            <tfoot>
                                                <tr class="table-active">
                                                    <th colspan="3">Course Average</th>
                                                    <th>
                                                        <span class="badge {% if courseData.average >= 10 %}bg-success{% else %}bg-danger{% endif %}">
                                                            {{ courseData.average }}/20
                                                        </span>
                                                    </th>
                                                </tr>
                                            </tfoot>
                                        </table>
                                    </div>
                                </div>
                            </div>
                        </div>
                        {% endfor %}
                    </div>
                    {% else %}
                    <div class="alert alert-info">
                        <i class="bi bi-info-circle-fill"></i> No results available yet.
                    </div>
                    {% endif %}
                </div>
            </div>
        </div>
    </div>
    
    <!-- Action Buttons -->
    <div class="mt-4">
        <a href="{{ path('app_espace_etudiant_dashboard') }}" class="btn btn-outline-secondary">
            <i class="bi bi-arrow-left"></i> Back to Dashboard
        </a>
        <a href="{{ path('app_espace_etudiant_grades') }}" class="btn btn-outline-primary">
            <i class="bi bi-list-ol"></i> My Grades
        </a>
        <a href="{{ path('app_espace_etudiant_recommendations') }}" class="btn btn-warning">
            <i class="bi bi-lightbulb-fill"></i> View Recommendations
        </a>
        <button onclick="window.print()" class="btn btn-primary">
            <i class="bi bi-printer-fill"></i> Print
        </button>
    </div>
</div>
{% endblock %}
