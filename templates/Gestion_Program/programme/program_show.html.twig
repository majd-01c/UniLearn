{% extends 'base.html.twig' %}

{% block title %}{{ program.name }} - UniLearn{% endblock %}

{% block body %}
<div class="container-fluid py-4">
    <nav aria-label="breadcrumb" class="mb-4">
        <ol class="breadcrumb">
            <li class="breadcrumb-item"><a href="{{ path('app_home') }}">Home</a></li>
            <li class="breadcrumb-item"><a href="{{ path('app_programme_programs') }}">Programs</a></li>
            <li class="breadcrumb-item active">{{ program.name }}</li>
        </ol>
    </nav>

    {# Header Section #}
    <div class="row mb-4">
        <div class="col-md-8">
            <div class="d-flex align-items-center gap-3">
                <div class="bg-success bg-opacity-10 p-3 rounded">
                    <i class="bi bi-collection text-success" style="font-size: 2rem;"></i>
                </div>
                <div>
                    <h1 class="h2 mb-1">{{ program.name }}</h1>
                    <div class="d-flex gap-2 align-items-center">
                        {% if program.published %}
                            <span class="badge bg-success"><i class="bi bi-check-circle"></i> Published</span>
                        {% else %}
                            <span class="badge bg-warning text-dark"><i class="bi bi-clock"></i> Draft</span>
                        {% endif %}
                        <span class="text-muted small">|</span>
                        <span class="text-muted small"><i class="bi bi-calendar3"></i> Updated: {{ program.updatedAt|date('M d, Y') }}</span>
                    </div>
                </div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="d-flex gap-2 justify-content-end">
                <a href="{{ path('app_programme_programs_edit', {id: program.id}) }}" class="btn btn-outline-primary">
                    <i class="bi bi-pencil-square"></i> Edit Program
                </a>
                <a href="{{ path('app_programme_programs') }}" class="btn btn-outline-secondary">
                    <i class="bi bi-arrow-left"></i> Back
                </a>
            </div>
        </div>
    </div>

    {# Main Content #}
    <div class="row g-4">
        {# Left Column - Modules List #}
        <div class="col-lg-{% if is_granted('ROLE_ADMIN') %}12{% else %}8{% endif %}">
            <div class="card card-elevated border-0 shadow-sm">
                <div class="card-header bg-white border-bottom d-flex justify-content-between align-items-center">
                    <div>
                        <h5 class="mb-0"><i class="bi bi-grid-3x3-gap text-primary"></i> Module Curriculum</h5>
                        <small class="text-muted">{{ program.modules|length }} module(s) in this program</small>
                    </div>
                </div>
                
                {% if program.modules is empty %}
                    <div class="card-body">
                        <div class="text-center py-5">
                            <div class="mb-3">
                                <i class="bi bi-inbox text-muted" style="font-size: 3rem; opacity: 0.5;"></i>
                            </div>
                            <h6 class="text-muted">No modules assigned yet</h6>
                            <p class="small text-muted">Start by adding modules to structure this program's curriculum.</p>
                        </div>
                    </div>
                {% else %}
                    <div class="card-body p-0">
                        <div class="list-group list-group-flush">
                            {% for programModule in program.modules %}
                            <div class="list-group-item border-bottom-light px-4 py-3 d-flex justify-content-between align-items-center hover-lift transition-all">
                                <div class="flex-grow-1">
                                    <div class="d-flex align-items-center gap-3">
                                        <div class="bg-primary bg-opacity-10 p-2 rounded" style="width: 40px; height: 40px; display: flex; align-items: center; justify-content: center;">
                                            <i class="bi bi-book-fill text-primary"></i>
                                        </div>
                                        <div>
                                            <a href="{{ path('app_programme_modules_show', {id: programModule.module.id}) }}" class="text-decoration-none text-dark fw-500">
                                                {{ programModule.module.name }}
                                            </a>
                                            <div class="small text-muted mt-1">
                                                <i class="bi bi-hourglass-split"></i> {{ programModule.module.duration }} {{ programModule.module.periodUnit.value }}
                                                <span class="mx-2">•</span>
                                                <i class="bi bi-journal-text"></i> {{ programModule.module.courses|length }} course(s)
                                            </div>
                                        </div>
                                    </div>
                                </div>
                                {% if is_granted('ROLE_ADMIN') %}
                                <form method="post" action="{{ path('app_programme_programs_remove_module', {id: program.id, moduleId: programModule.module.id}) }}" class="d-inline ms-3">
                                    <input type="hidden" name="_token" value="{{ csrf_token('remove_module' ~ programModule.module.id) }}">
                                    <button type="submit" class="btn btn-sm btn-outline-danger" 
                                            onclick="return confirm('Remove this module from the program?')">
                                        <i class="bi bi-trash"></i>
                                    </button>
                                </form>
                                {% endif %}
                            </div>
                            {% endfor %}
                        </div>
                    </div>
                {% endif %}
            </div>
        </div>

        {# Right Column #}
        <div class="col-lg-4">
            {% if not is_granted('ROLE_ADMIN') %}
            {# Add Module Form for non-admins #}
            <div class="card card-elevated border-0 shadow-sm">
                <div class="card-header bg-primary text-white border-0">
                    <h6 class="mb-0"><i class="bi bi-plus-circle"></i> Add Module</h6>
                </div>
                <div class="card-body">
                    {% if availableModules is empty %}
                        <div class="text-center py-4">
                            <i class="bi bi-check-circle text-success mb-2" style="font-size: 2rem;"></i>
                            <p class="text-muted mb-3">All modules have been assigned</p>
                            <a href="{{ path('app_programme_modules_new') }}" class="btn btn-sm btn-outline-primary w-100">
                                <i class="bi bi-plus"></i> Create New Module
                            </a>
                        </div>
                    {% else %}
                        <form method="post" action="{{ path('app_programme_programs_add_module', {id: program.id}) }}">
                            <input type="hidden" name="_token" value="{{ csrf_token('add_module') }}">
                            <div class="mb-3">
                                <label for="module_id" class="form-label fw-500">Select Module</label>
                                <select name="module_id" id="module_id" class="form-select" required>
                                    <option value="">-- Choose a module --</option>
                                    {% for module in availableModules %}
                                        <option value="{{ module.id }}">{{ module.name }} ({{ module.duration }} {{ module.periodUnit.value }})</option>
                                    {% endfor %}
                                </select>
                            </div>
                            <button type="submit" class="btn btn-primary w-100">
                                <i class="bi bi-plus-circle"></i> Add Module
                            </button>
                        </form>
                    {% endif %}
                </div>
            </div>
            {% else %}
            {# Program Info Card for Admins #}
            <div class="card card-elevated border-0 shadow-sm">
                <div class="card-header bg-white border-bottom">
                    <h6 class="mb-0"><i class="bi bi-info-circle-fill text-info"></i> Program Information</h6>
                </div>
                <div class="card-body">
                    <div class="mb-4">
                        <label class="form-label small text-muted">Status</label>
                        <div>
                            {% if program.published %}
                                <span class="badge bg-success"><i class="bi bi-check-circle"></i> Published</span>
                            {% else %}
                                <span class="badge bg-warning text-dark"><i class="bi bi-clock"></i> Draft</span>
                            {% endif %}
                        </div>
                    </div>
                    <div class="mb-4">
                        <label class="form-label small text-muted">Total Modules</label>
                        <div class="h5 mb-0">
                            <i class="bi bi-grid-3x3-gap text-primary"></i> {{ program.modules|length }}
                        </div>
                    </div>
                    <div class="mb-4">
                        <label class="form-label small text-muted">Total Courses</label>
                        <div class="h5 mb-0">
                            <i class="bi bi-journal-text text-success"></i>
                            {% set totalCourses = 0 %}
                            {% for programModule in program.modules %}
                                {% set totalCourses = totalCourses + programModule.module.courses|length %}
                            {% endfor %}
                            {{ totalCourses }}
                        </div>
                    </div>
                    <div class="mb-3">
                        <label class="form-label small text-muted">Created Date</label>
                        <p class="mb-0 small">{{ program.createdAt|date('M d, Y H:i') }}</p>
                    </div>
                    <div>
                        <label class="form-label small text-muted">Last Updated</label>
                        <p class="mb-0 small">{{ program.updatedAt|date('M d, Y H:i') }}</p>
                    </div>
                </div>
            </div>
            {% endif %}
        </div>
    </div>
</div>

<style>
    .card-elevated {
        border-radius: 0.5rem;
        transition: transform 0.2s, box-shadow 0.2s;
    }
    
    .card-elevated:hover {
        box-shadow: 0 0.5rem 1rem rgba(0, 0, 0, 0.1) !important;
    }
    
    .hover-lift {
        transition: transform 0.2s, background-color 0.2s;
    }
    
    .hover-lift:hover {
        background-color: rgba(0, 0, 0, 0.02);
        transform: translateY(-2px);
    }
    
    .transition-all {
        transition: all 0.3s ease;
    }
    
    .border-bottom-light {
        border-bottom: 1px solid rgba(0, 0, 0, 0.05) !important;
    }
    
    .fw-500 {
        font-weight: 500;
    }
</style>
{% endblock %}
