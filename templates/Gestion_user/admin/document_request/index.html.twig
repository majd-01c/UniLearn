{% extends 'base.html.twig' %}

{% block title %}Document Request Management{% endblock %}

{% block body %}
<div class="container-fluid mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h1><i class="bi bi-file-earmark-text"></i> Document Request Management</h1>
    </div>

    <div class="card">
        <div class="card-body">
            <div class="table-responsive">
                <table class="table table-hover">
                    <thead class="table-dark">
                        <tr>
                            <th>ID</th>
                            <th>Student</th>
                            <th>Document Type</th>
                            <th>Status</th>
                            <th>Request Date</th>
                            <th>Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        {% for request in documentRequests %}
                        <tr>
                            <td>{{ request.id }}</td>
                            <td>{{ request.student.name ?? request.student.email }}</td>
                            <td>
                                {% if request.documentType == 'attestation_stage' %}
                                    Internship Certificate
                                {% elseif request.documentType == 'attestation_inscription' %}
                                    Enrollment Certificate
                                {% elseif request.documentType == 'releve_notes' %}
                                    Transcript
                                {% elseif request.documentType == 'attestation_reussite' %}
                                    Certificate of Achievement
                                {% elseif request.documentType == 'certificat_scolarite' %}
                                    Student Status Certificate
                                {% else %}
                                    {{ request.documentType }}
                                {% endif %}
                            </td>
                            <td>
                                <span class="badge 
                                    {% if request.status == 'pending' %}bg-warning
                                    {% elseif request.status == 'approved' %}bg-info
                                    {% elseif request.status == 'ready' %}bg-success
                                    {% elseif request.status == 'delivered' %}bg-primary
                                    {% else %}bg-danger{% endif %}">
                                    {% if request.status == 'pending' %}Pending
                                    {% elseif request.status == 'approved' %}Approved
                                    {% elseif request.status == 'ready' %}Ready
                                    {% elseif request.status == 'delivered' %}Delivered
                                    {% else %}Rejected{% endif %}
                                </span>
                            </td>
                            <td>{{ request.requestedAt|date('d/m/Y H:i') }}</td>
                            <td>
                                <a href="{{ path('app_admin_document_request_show', {id: request.id}) }}" class="btn btn-sm btn-primary">
                                    <i class="bi bi-eye"></i> View
                                </a>
                            </td>
                        </tr>
                        {% else %}
                        <tr>
                            <td colspan="6" class="text-center text-muted">No requests found</td>
                        </tr>
                        {% endfor %}
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>
{% endblock %}

