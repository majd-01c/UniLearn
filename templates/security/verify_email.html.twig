{% extends 'base.html.twig' %}

{% block title %}{{ 'auth.verify_email_title'|trans }} - UniLearn{% endblock %}

{% block body %}
<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-6">
            <div class="card shadow-lg">
                <div class="card-header bg-primary text-white text-center py-4">
                    <h3 class="mb-0">
                        <i class="bi bi-envelope-check-fill"></i> {{ 'auth.verify_email_title'|trans }}
                    </h3>
                </div>
                <div class="card-body p-4">
                    {% for label, messages in app.flashes %}
                        {% for message in messages %}
                            <div class="alert alert-{{ label == 'error' ? 'danger' : label }} alert-dismissible fade show" role="alert">
                                {{ message }}
                                <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                            </div>
                        {% endfor %}
                    {% endfor %}

                    <div class="alert alert-info mb-4">
                        <i class="bi bi-info-circle-fill"></i> <strong>{{ 'auth.verify_email_title'|trans }}</strong>
                        <p class="mb-0 mt-2">{{ 'auth.verify_email_desc'|trans }}</p>
                        {% if codeExpiryDate is defined and codeExpiryDate %}
                        <p class="mb-0 mt-2">
                            {{ 'auth.code_expires_in'|trans }}: <strong id="countdown-timer">--:--</strong>
                        </p>
                        {% endif %}
                    </div>

                    {% if expired is defined and expired %}
                        <div class="alert alert-warning">
                            <i class="bi bi-hourglass-split"></i> {{ 'auth.code_expired'|trans }}
                        </div>
                    {% endif %}

                    <div class="alert alert-danger d-none" id="expiry-alert">
                        <i class="bi bi-hourglass-bottom"></i> <strong>{{ 'auth.code_expired'|trans }}</strong>
                    </div>

                    <form method="post" id="verificationForm">
                        <div class="mb-4">
                            <label for="verification_code" class="form-label fw-bold">
                                <i class="bi bi-shield-lock-fill"></i> {{ 'auth.verification_code'|trans }}
                            </label>
                            <input 
                                type="text" 
                                class="form-control form-control-lg text-center" 
                                id="verification_code" 
                                name="verification_code" 
                                placeholder="000000"
                                maxlength="6"
                                pattern="[0-9]{6}"
                                required
                                autofocus
                                style="letter-spacing: 10px; font-size: 24px; font-weight: bold;"
                            >
                            <small class="form-text text-muted">Enter the 6-digit code sent to your email</small>
                        </div>

                        <div class="d-grid gap-2">
                            <button type="submit" class="btn btn-primary btn-lg">
                                <i class="bi bi-check2-circle"></i> {{ 'auth.verify'|trans }}
                            </button>
                        </div>
                    </form>

                    <hr class="my-4">

                    <div class="text-center">
                        <p class="text-muted mb-2">{{ 'auth.resend_code'|trans }}</p>
                        <form method="post" action="{{ path('app_verify_resend') }}" class="d-inline">
                            <button type="submit" class="btn btn-outline-secondary">
                                <i class="bi bi-send-fill"></i> {{ 'auth.resend_code'|trans }}
                            </button>
                        </form>
                    </div>

                    <div class="alert alert-warning mt-4 mb-0">
                        <small>
                            <i class="bi bi-exclamation-circle-fill"></i> <strong>Note:</strong> Your account will not be fully activated until you verify your email address.
                        </small>
                    </div>
                </div>
            </div>

            <div class="text-center mt-3">
                <a href="{{ path('app_home') }}" class="text-muted">
                    <i class="bi bi-arrow-left"></i> Back to Home
                </a>
            </div>
        </div>
    </div>
</div>

<script>
    // Auto-format verification code input
    document.getElementById('verification_code').addEventListener('input', function(e) {
        this.value = this.value.replace(/[^0-9]/g, '');
    });

    {% if codeExpiryDate is defined and codeExpiryDate and not (expired is defined and expired) %}
    (function () {
        var expiryTime = {{ codeExpiryDate|date('U') * 1000 }};
        var timerEl = document.getElementById('countdown-timer');
        var expiryAlert = document.getElementById('expiry-alert');
        var submitBtn = document.querySelector('#verificationForm button[type="submit"]');
        var codeInput = document.getElementById('verification_code');

        function updateCountdown() {
            var remaining = Math.max(0, Math.floor((expiryTime - Date.now()) / 1000));
            var mins = Math.floor(remaining / 60);
            var secs = remaining % 60;
            if (timerEl) {
                timerEl.textContent = mins + ':' + (secs < 10 ? '0' : '') + secs;
                timerEl.style.color = remaining <= 15 ? '#dc3545' : '';
            }
            if (remaining === 0) {
                clearInterval(interval);
                if (expiryAlert) expiryAlert.classList.remove('d-none');
                if (submitBtn) submitBtn.disabled = true;
                if (codeInput) codeInput.disabled = true;
                if (timerEl) timerEl.textContent = '0:00';
            }
        }

        updateCountdown();
        var interval = setInterval(updateCountdown, 1000);
    })();
    {% endif %}
</script>
{% endblock %}
