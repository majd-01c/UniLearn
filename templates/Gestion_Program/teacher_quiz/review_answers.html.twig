{% extends 'base.html.twig' %}

{% block title %}Review Answers - {{ userAnswer.user.name }} - {{ quiz.title }} - UniLearn{% endblock %}

{% block stylesheets %}
{{ parent() }}
<style>
    .review-container {
        max-width: 1000px;
        margin: 0 auto;
    }

    .student-header {
        background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
        color: white;
        border-radius: 16px;
        padding: 2rem;
        margin-bottom: 2rem;
        box-shadow: 0 10px 40px rgba(102, 126, 234, 0.3);
    }

    .answer-card {
        background: white;
        border-radius: 16px;
        box-shadow: 0 4px 20px rgba(0,0,0,0.08);
        margin-bottom: 1.5rem;
        overflow: hidden;
        border: 2px solid transparent;
        transition: border-color 0.3s ease;
    }

    .answer-card.ai-high {
        border-color: #dc3545;
    }

    .answer-card.ai-medium {
        border-color: #ffc107;
    }

    .answer-card.ai-low {
        border-color: #28a745;
    }

    .answer-header {
        background: linear-gradient(90deg, #f8f9fa 0%, #e9ecef 100%);
        padding: 1rem 1.5rem;
        display: flex;
        justify-content: space-between;
        align-items: center;
        border-bottom: 1px solid #e9ecef;
    }

    .answer-body {
        padding: 1.5rem;
    }

    .answer-text {
        background: #f8f9fa;
        border-radius: 12px;
        padding: 1.25rem;
        font-size: 1rem;
        line-height: 1.7;
        color: #212529;
        border-left: 4px solid #667eea;
        margin-bottom: 1rem;
    }

    .ai-detection-panel {
        border-radius: 12px;
        padding: 1.25rem;
        margin-top: 1rem;
        display: none;
    }

    .ai-detection-panel.visible {
        display: block;
    }

    .ai-score-badge {
        display: inline-flex;
        align-items: center;
        gap: 0.5rem;
        padding: 0.5rem 1rem;
        border-radius: 20px;
        font-weight: 600;
        font-size: 1rem;
    }

    .ai-score-high {
        background: #f8d7da;
        color: #721c24;
    }

    .ai-score-medium {
        background: #fff3cd;
        color: #856404;
    }

    .ai-score-low {
        background: #d4edda;
        color: #155724;
    }

    .indicator-tag {
        display: inline-block;
        background: #e9ecef;
        color: #495057;
        border-radius: 20px;
        padding: 0.25rem 0.75rem;
        font-size: 0.8rem;
        margin: 0.25rem;
    }

    .indicator-tag.flagged {
        background: #f8d7da;
        color: #721c24;
    }

    .scan-btn {
        background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
        border: none;
        color: white;
        padding: 0.5rem 1.25rem;
        border-radius: 10px;
        font-weight: 600;
        transition: all 0.3s ease;
        box-shadow: 0 4px 15px rgba(102, 126, 234, 0.3);
    }

    .scan-btn:hover {
        transform: translateY(-1px);
        box-shadow: 0 6px 20px rgba(102, 126, 234, 0.4);
        color: white;
    }

    .scan-btn:disabled {
        opacity: 0.6;
        transform: none;
    }

    .scan-all-btn {
        background: linear-gradient(135deg, #ff6b6b 0%, #ee5a24 100%);
        border: none;
        color: white;
        padding: 0.75rem 2rem;
        border-radius: 12px;
        font-weight: 600;
        font-size: 1.05rem;
        transition: all 0.3s ease;
        box-shadow: 0 4px 15px rgba(255, 107, 107, 0.3);
    }

    .scan-all-btn:hover {
        transform: translateY(-2px);
        box-shadow: 0 6px 25px rgba(255, 107, 107, 0.4);
        color: white;
    }

    .scan-all-btn:disabled {
        opacity: 0.6;
        transform: none;
    }

    .loading-spinner {
        display: inline-block;
        width: 18px;
        height: 18px;
        border: 2px solid rgba(255,255,255,0.3);
        border-radius: 50%;
        border-top-color: white;
        animation: spin 0.8s ease infinite;
    }

    @keyframes spin {
        to { transform: rotate(360deg); }
    }

    .score-meter {
        height: 8px;
        border-radius: 4px;
        background: #e9ecef;
        overflow: hidden;
        margin-top: 0.5rem;
    }

    .score-meter-fill {
        height: 100%;
        border-radius: 4px;
        transition: width 0.5s ease;
    }

    .no-text-answers {
        text-align: center;
        padding: 4rem 2rem;
        color: #6c757d;
    }

    .no-text-answers i {
        font-size: 4rem;
        margin-bottom: 1rem;
    }

    .cheat-badge {
        background: #dc3545;
        color: white;
        padding: 0.25rem 0.75rem;
        border-radius: 20px;
        font-size: 0.8rem;
        font-weight: 600;
    }

    .summary-card {
        background: white;
        border-radius: 16px;
        box-shadow: 0 4px 20px rgba(0,0,0,0.08);
        padding: 1.5rem;
        margin-bottom: 1.5rem;
    }
</style>
{% endblock %}

{% block body %}
<div class="container-fluid py-4">
    <div class="review-container">
        {# Back Button #}
        <a href="{{ path('app_teacher_quiz_results', {teacherClasseId: teacherClasse.id, quizId: quiz.id}) }}" class="btn btn-light mb-3">
            <i class="bi bi-arrow-left me-2"></i> Back to Results
        </a>

        {# Student Header #}
        <div class="student-header">
            <div class="d-flex align-items-center justify-content-between">
                <div class="d-flex align-items-center">
                    {% if userAnswer.user.profile and userAnswer.user.profile.avatarFilename %}
                        <img src="{{ vich_uploader_asset(userAnswer.user.profile, 'avatarFile') }}" 
                             class="rounded-circle me-3" width="60" height="60" alt="" style="border: 3px solid rgba(255,255,255,0.3);">
                    {% else %}
                        <div class="rounded-circle bg-white bg-opacity-25 d-flex align-items-center justify-content-center me-3"
                             style="width: 60px; height: 60px;">
                            <i class="bi bi-person-fill text-white" style="font-size: 1.5rem;"></i>
                        </div>
                    {% endif %}
                    <div>
                        <h2 class="mb-0">{{ userAnswer.user.name }}</h2>
                        <p class="mb-0 opacity-75">{{ userAnswer.user.email }}</p>
                    </div>
                </div>
                <div class="text-end">
                    <div class="fs-3 fw-bold">
                        {% if userAnswer.totalPoints > 0 %}
                            {{ ((userAnswer.score / userAnswer.totalPoints) * 100)|round }}%
                        {% else %}
                            0%
                        {% endif %}
                    </div>
                    <div class="opacity-75">{{ userAnswer.score ?? 0 }} / {{ userAnswer.totalPoints ?? 0 }} pts</div>
                    {% if userAnswer.isCheated %}
                        <span class="cheat-badge mt-1"><i class="bi bi-exclamation-triangle-fill me-1"></i> Cheating Detected</span>
                    {% endif %}
                </div>
            </div>
            <div class="mt-3 opacity-75">
                <i class="bi bi-book me-1"></i> {{ quiz.title }}
                <span class="mx-2">|</span>
                <i class="bi bi-clock me-1"></i> Completed: {{ userAnswer.completedAt ? userAnswer.completedAt|date('M d, Y H:i') : 'In Progress' }}
            </div>
        </div>

        {% if textAnswers|length == 0 %}
            <div class="summary-card no-text-answers">
                <i class="bi bi-chat-square-text"></i>
                <h4>No Text Answers</h4>
                <p>This quiz has no open-text questions to review for AI detection.</p>
            </div>
        {% else %}
            {# Scan All Button #}
            <div class="summary-card d-flex align-items-center justify-content-between">
                <div>
                    <h5 class="mb-1"><i class="bi bi-robot me-2 text-primary"></i>AI Content Detection</h5>
                    <p class="text-muted mb-0">Scan text answers to detect potential AI-generated content</p>
                </div>
                <button class="btn scan-all-btn" id="scan-all-btn" onclick="scanAllAnswers()">
                    <i class="bi bi-shield-check me-2"></i> Scan All Answers
                </button>
            </div>

            {# Text Answers #}
            {% for answer in textAnswers %}
                <div class="answer-card" id="answer-card-{{ answer.id }}">
                    <div class="answer-header">
                        <div>
                            <span class="fw-bold text-dark">
                                <i class="bi bi-question-circle me-1"></i> Question {{ loop.index }}
                            </span>
                            <span class="text-muted ms-2">({{ answer.question.points }} pt{{ answer.question.points > 1 ? 's' : '' }})</span>
                        </div>
                        <div class="d-flex align-items-center gap-2">
                            {% if answer.isCorrect %}
                                <span class="badge bg-success">
                                    <i class="bi bi-check"></i> +{{ answer.pointsEarned }} pts
                                </span>
                            {% elseif answer.pointsEarned > 0 %}
                                <span class="badge bg-warning text-dark">
                                    <i class="bi bi-dash"></i> +{{ answer.pointsEarned }} pts
                                </span>
                            {% else %}
                                <span class="badge bg-danger">
                                    <i class="bi bi-x"></i> 0 pts
                                </span>
                            {% endif %}
                            <span class="ai-result-badge-{{ answer.id }}">
                                {% if answer.aiDetectionScore is not null %}
                                    {% if answer.aiDetectionScore >= 70 %}
                                        <span class="ai-score-badge ai-score-high">
                                            <i class="bi bi-robot"></i> {{ answer.aiDetectionScore|round }}% AI
                                        </span>
                                    {% elseif answer.aiDetectionScore >= 40 %}
                                        <span class="ai-score-badge ai-score-medium">
                                            <i class="bi bi-robot"></i> {{ answer.aiDetectionScore|round }}% AI
                                        </span>
                                    {% else %}
                                        <span class="ai-score-badge ai-score-low">
                                            <i class="bi bi-person"></i> {{ answer.aiDetectionScore|round }}% AI
                                        </span>
                                    {% endif %}
                                {% endif %}
                            </span>
                        </div>
                    </div>
                    <div class="answer-body">
                        <p class="text-muted fw-medium mb-2">{{ answer.question.questionText }}</p>
                        
                        <div class="answer-text">
                            {{ answer.textAnswer ?? 'No answer provided' }}
                        </div>

                        {% if answer.question.explanation %}
                            <div class="alert alert-info py-2 mb-3">
                                <i class="bi bi-lightbulb me-1"></i>
                                <strong>Expected Answer:</strong> {{ answer.question.explanation }}
                            </div>
                        {% endif %}

                        <div class="d-flex justify-content-end">
                            <button class="btn scan-btn" 
                                    id="scan-btn-{{ answer.id }}"
                                    onclick="scanAnswer({{ answer.id }})">
                                <i class="bi bi-shield-check me-1"></i> Scan for AI
                            </button>
                        </div>

                        {# AI Detection Result Panel #}
                        <div class="ai-detection-panel {{ answer.aiDetectionScore is not null ? 'visible' : '' }}" 
                             id="ai-panel-{{ answer.id }}">
                            {% if answer.aiDetectionScore is not null %}
                                {% set storedResult = answer.aiDetectionResultDecoded %}
                                <div class="d-flex align-items-center justify-content-between mb-3">
                                    <h6 class="mb-0"><i class="bi bi-robot me-1"></i> AI Detection Result</h6>
                                    {% if answer.aiDetectionScore >= 70 %}
                                        <span class="ai-score-badge ai-score-high">
                                            <i class="bi bi-exclamation-triangle-fill"></i> {{ answer.aiDetectionScore|round }}% AI Probability
                                        </span>
                                    {% elseif answer.aiDetectionScore >= 40 %}
                                        <span class="ai-score-badge ai-score-medium">
                                            <i class="bi bi-question-circle-fill"></i> {{ answer.aiDetectionScore|round }}% AI Probability
                                        </span>
                                    {% else %}
                                        <span class="ai-score-badge ai-score-low">
                                            <i class="bi bi-check-circle-fill"></i> {{ answer.aiDetectionScore|round }}% AI Probability
                                        </span>
                                    {% endif %}
                                </div>
                                <div class="score-meter">
                                    <div class="score-meter-fill {{ answer.aiDetectionScore >= 70 ? 'bg-danger' : (answer.aiDetectionScore >= 40 ? 'bg-warning' : 'bg-success') }}" 
                                         style="width: {{ answer.aiDetectionScore }}%"></div>
                                </div>
                                {% if storedResult %}
                                    <p class="mt-3 mb-2">{{ storedResult.analysis ?? '' }}</p>
                                    {% if storedResult.indicators is defined and storedResult.indicators|length > 0 %}
                                        <div class="mt-2">
                                            <small class="text-muted fw-medium">Indicators found:</small><br>
                                            {% for indicator in storedResult.indicators %}
                                                <span class="indicator-tag flagged">{{ indicator }}</span>
                                            {% endfor %}
                                        </div>
                                    {% endif %}
                                {% endif %}
                            {% endif %}
                        </div>
                    </div>
                </div>
            {% endfor %}
        {% endif %}
    </div>
</div>

<script>
const DETECT_SINGLE_URL_TEMPLATE = '{{ path('app_teacher_quiz_detect_ai', {teacherClasseId: teacherClasse.id, quizId: quiz.id, answerId: 0}) }}';
const DETECT_ALL_URL = '{{ path('app_teacher_quiz_detect_all_ai', {teacherClasseId: teacherClasse.id, quizId: quiz.id, userAnswerId: userAnswer.id}) }}';

function getDetectUrl(answerId) {
    return DETECT_SINGLE_URL_TEMPLATE.replace('/0/', '/' + answerId + '/');
}

function scanAnswer(answerId) {
    const btn = document.getElementById('scan-btn-' + answerId);
    const panel = document.getElementById('ai-panel-' + answerId);
    const card = document.getElementById('answer-card-' + answerId);
    const badgeContainer = document.querySelector('.ai-result-badge-' + answerId);
    
    btn.disabled = true;
    btn.innerHTML = '<span class="loading-spinner me-1"></span> Scanning...';
    
    fetch(getDetectUrl(answerId), {
        method: 'POST',
        headers: {
            'Content-Type': 'application/json',
            'X-Requested-With': 'XMLHttpRequest'
        }
    })
    .then(response => response.json())
    .then(data => {
        if (data.success) {
            displayResult(answerId, data, panel, card, badgeContainer);
        } else {
            panel.innerHTML = '<div class="alert alert-danger"><i class="bi bi-exclamation-triangle"></i> ' + (data.error || 'Detection failed') + '</div>';
            panel.classList.add('visible');
        }
        btn.disabled = false;
        btn.innerHTML = '<i class="bi bi-shield-check me-1"></i> Rescan';
    })
    .catch(err => {
        panel.innerHTML = '<div class="alert alert-danger"><i class="bi bi-exclamation-triangle"></i> Failed to connect to server.</div>';
        panel.classList.add('visible');
        btn.disabled = false;
        btn.innerHTML = '<i class="bi bi-shield-check me-1"></i> Scan for AI';
    });
}

function scanAllAnswers() {
    const btn = document.getElementById('scan-all-btn');
    btn.disabled = true;
    btn.innerHTML = '<span class="loading-spinner me-2"></span> Scanning all answers...';
    
    fetch(DETECT_ALL_URL, {
        method: 'POST',
        headers: {
            'Content-Type': 'application/json',
            'X-Requested-With': 'XMLHttpRequest'
        }
    })
    .then(response => response.json())
    .then(data => {
        if (data.success && data.results) {
            data.results.forEach(function(result) {
                const panel = document.getElementById('ai-panel-' + result.answerId);
                const card = document.getElementById('answer-card-' + result.answerId);
                const badgeContainer = document.querySelector('.ai-result-badge-' + result.answerId);
                const scanBtn = document.getElementById('scan-btn-' + result.answerId);
                
                if (panel && card) {
                    displayResult(result.answerId, result, panel, card, badgeContainer);
                    if (scanBtn) {
                        scanBtn.innerHTML = '<i class="bi bi-shield-check me-1"></i> Rescan';
                    }
                }
            });
        }
        btn.disabled = false;
        btn.innerHTML = '<i class="bi bi-shield-check me-2"></i> Rescan All';
    })
    .catch(err => {
        alert('Failed to scan answers. Please try again.');
        btn.disabled = false;
        btn.innerHTML = '<i class="bi bi-shield-check me-2"></i> Scan All Answers';
    });
}

function displayResult(answerId, data, panel, card, badgeContainer) {
    const prob = data.aiProbability;
    let colorClass, iconClass, bgClass, barClass;
    
    if (prob >= 70) {
        colorClass = 'ai-score-high';
        iconClass = 'bi-exclamation-triangle-fill';
        bgClass = 'ai-high';
        barClass = 'bg-danger';
    } else if (prob >= 40) {
        colorClass = 'ai-score-medium';
        iconClass = 'bi-question-circle-fill';
        bgClass = 'ai-medium';
        barClass = 'bg-warning';
    } else {
        colorClass = 'ai-score-low';
        iconClass = 'bi-check-circle-fill';
        bgClass = 'ai-low';
        barClass = 'bg-success';
    }
    
    // Update card border
    card.className = 'answer-card ' + bgClass;
    
    // Update header badge
    if (badgeContainer) {
        badgeContainer.innerHTML = '<span class="ai-score-badge ' + colorClass + '">' +
            '<i class="bi bi-robot"></i> ' + Math.round(prob) + '% AI</span>';
    }
    
    // Build indicators HTML
    let indicatorsHtml = '';
    if (data.indicators && data.indicators.length > 0) {
        indicatorsHtml = '<div class="mt-2"><small class="text-muted fw-medium">Indicators found:</small><br>';
        data.indicators.forEach(function(ind) {
            indicatorsHtml += '<span class="indicator-tag flagged">' + ind + '</span>';
        });
        indicatorsHtml += '</div>';
    }
    
    panel.innerHTML = `
        <div class="d-flex align-items-center justify-content-between mb-3">
            <h6 class="mb-0"><i class="bi bi-robot me-1"></i> AI Detection Result</h6>
            <span class="ai-score-badge ${colorClass}">
                <i class="bi ${iconClass}"></i> ${Math.round(prob)}% AI Probability
            </span>
        </div>
        <div class="score-meter">
            <div class="score-meter-fill ${barClass}" style="width: ${prob}%"></div>
        </div>
        <p class="mt-3 mb-2">${data.analysis || ''}</p>
        ${indicatorsHtml}
    `;
    panel.classList.add('visible');
}
</script>
{% endblock %}
